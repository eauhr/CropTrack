<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CropTrackApp.Pages.MarketPricesPage"
             BackgroundColor="#F3F5F7"
             Title="Market Prices">
    <Grid RowDefinitions="Auto,Auto,Auto,*" Padding="16">
        <Label Grid.Row="0"
               Text="Market Prices"
               FontSize="28"
               FontAttributes="Bold"
               TextColor="#1E2A33"
               Margin="0,0,0,12" />

        <Grid Grid.Row="1" ColumnDefinitions="*,Auto" ColumnSpacing="8">
            <Picker x:Name="CropPicker"
                    Grid.Column="0"
                    Title="Select crop"
                    ItemDisplayBinding="{Binding Name}" />
            <Button Grid.Column="1"
                    Text="Fetch"
                    Clicked="OnFetchClicked"
                    BackgroundColor="#EF6C00"
                    TextColor="White"
                    CornerRadius="10"
                    HeightRequest="42" />
        </Grid>

        <Grid Grid.Row="2" ColumnDefinitions="*,*" ColumnSpacing="8" Margin="0,10,0,10">
            <Picker Grid.Column="0"
                    x:Name="TimeRangePicker"
                    Title="Time range"
                    SelectedIndexChanged="OnFilterChanged">
                <Picker.ItemsSource>
                    <x:Array Type="{x:Type x:String}">
                        <x:String>All time</x:String>
                        <x:String>Last 30 days</x:String>
                        <x:String>Last 90 days</x:String>
                    </x:Array>
                </Picker.ItemsSource>
            </Picker>
            <Label Grid.Column="1"
                   x:Name="TrendLabel"
                   VerticalTextAlignment="Center"
                   HorizontalTextAlignment="End"
                   TextColor="#5D6A77"
                   FontAttributes="Bold"
                   Text="Trend: N/A" />
        </Grid>

        <Grid Grid.Row="3">
            <RefreshView x:Name="PricesRefreshView" Refreshing="OnRefreshRequested">
                <CollectionView x:Name="PricesCollectionView" SelectionMode="None">
                    <CollectionView.EmptyView>
                        <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="8" Margin="0,80,0,0">
                            <Label Text="No prices found" FontSize="20" FontAttributes="Bold" TextColor="#4F5D6B" HorizontalOptions="Center" />
                            <Label Text="Fetch prices or add a new market entry." TextColor="#6A7988" HorizontalOptions="Center" />
                        </VerticalStackLayout>
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <SwipeView>
                                <SwipeView.LeftItems>
                                    <SwipeItems>
                                        <SwipeItem Text="Edit"
                                                   BackgroundColor="#1565C0"
                                                   Invoked="OnEditPriceSwipeInvoked"
                                                   CommandParameter="{Binding .}" />
                                    </SwipeItems>
                                </SwipeView.LeftItems>
                                <SwipeView.RightItems>
                                    <SwipeItems>
                                        <SwipeItem Text="Delete"
                                                   BackgroundColor="#C62828"
                                                   Invoked="OnDeletePriceSwipeInvoked"
                                                   CommandParameter="{Binding .}" />
                                    </SwipeItems>
                                </SwipeView.RightItems>
                                <Border Margin="0,0,0,10"
                                        BackgroundColor="White"
                                        Stroke="#E3E8ED"
                                        StrokeThickness="1"
                                        StrokeShape="RoundRectangle 14"
                                        Padding="12">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <VerticalStackLayout Spacing="2">
                                            <Label Text="{Binding CropName}" FontSize="16" FontAttributes="Bold" TextColor="#1E2A33" />
                                            <Label Text="{Binding DateText}" FontSize="12" TextColor="#5B6A78" />
                                            <Label Text="{Binding ChangeText}" FontSize="12" TextColor="{Binding ChangeColor}" />
                                        </VerticalStackLayout>
                                        <Label Grid.Column="1"
                                               Text="{Binding PriceText}"
                                               FontSize="18"
                                               FontAttributes="Bold"
                                               VerticalTextAlignment="Center"
                                               TextColor="#0D1B2A" />
                                    </Grid>
                                </Border>
                            </SwipeView>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </RefreshView>

            <Button Text="+"
                    FontSize="28"
                    WidthRequest="60"
                    HeightRequest="60"
                    CornerRadius="30"
                    BackgroundColor="#EF6C00"
                    TextColor="White"
                    Clicked="OnAddPriceClicked"
                    HorizontalOptions="End"
                    VerticalOptions="End"
                    Margin="0,0,8,8" />
        </Grid>
    </Grid>
</ContentPage>
