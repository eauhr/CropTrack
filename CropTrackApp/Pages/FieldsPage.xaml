<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CropTrackApp.Pages.FieldsPage"
             Title="Fields &amp; Crops"
             BackgroundColor="#F5F7FA">

    <Grid RowDefinitions="Auto,Auto,Auto,Auto,*" Padding="16,16,16,8" RowSpacing="12">
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" VerticalOptions="Center">
            <Label Text="Fields &amp; Crops"
                   FontSize="28"
                   FontAttributes="Bold"
                   TextColor="#1E2A33" />
            <Button Grid.Column="1"
                    Text="+ Add Field"
                    Clicked="OnAddFieldClicked"
                    BackgroundColor="#2E7D32"
                    TextColor="White"
                    CornerRadius="14"
                    Padding="14,10" />
        </Grid>

        <SearchBar Grid.Row="1"
                   x:Name="FieldSearchBar"
                   Placeholder="Search field name or location"
                   TextChanged="OnSearchChanged"
                   BackgroundColor="White" />

        <HorizontalStackLayout Grid.Row="2" Spacing="10">
            <Picker x:Name="RegionFilterPicker"
                    Title="All Regions"
                    WidthRequest="180"
                    SelectedIndexChanged="OnFilterChanged" />
            <Picker x:Name="SortPicker"
                    Title="Sort"
                    WidthRequest="180"
                    SelectedIndexChanged="OnFilterChanged">
                <Picker.Items>
                    <x:String>Alphabetical</x:String>
                    <x:String>Largest acreage</x:String>
                    <x:String>Smallest acreage</x:String>
                </Picker.Items>
            </Picker>
        </HorizontalStackLayout>

        <Border Grid.Row="3"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 16"
                BackgroundColor="#E8F2FF"
                Padding="14,12">
            <VerticalStackLayout Spacing="4">
                <Label Text="Farm Snapshot"
                       FontSize="16"
                       FontAttributes="Bold"
                       TextColor="#174D8A" />
                <Label x:Name="MapSummaryLabel"
                       TextColor="#1E2A33"
                       FontSize="13" />
                <Label x:Name="RegionSpreadLabel"
                       TextColor="#4C5C68"
                       FontSize="12" />
            </VerticalStackLayout>
        </Border>

        <RefreshView Grid.Row="4"
                     x:Name="FieldsRefreshView"
                     Refreshing="OnRefreshRequested">
            <CollectionView x:Name="FieldsCollectionView"
                            SelectionMode="Single"
                            SelectionChanged="OnFieldSelected">
                <CollectionView.EmptyView>
                    <VerticalStackLayout Padding="0,36" Spacing="8">
                        <Label Text="No fields yet"
                               HorizontalTextAlignment="Center"
                               FontAttributes="Bold"
                               FontSize="18"
                               TextColor="#1E2A33" />
                        <Label Text="Add your first field and assign crops to it."
                               HorizontalTextAlignment="Center"
                               TextColor="#5B6870" />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <SwipeView>
                            <SwipeView.LeftItems>
                                <SwipeItems Mode="Reveal">
                                    <SwipeItem Text="Edit"
                                               BackgroundColor="#1565C0"
                                               Invoked="OnEditFieldSwipeInvoked"
                                               CommandParameter="{Binding .}" />
                                </SwipeItems>
                            </SwipeView.LeftItems>
                            <SwipeView.RightItems>
                                <SwipeItems Mode="Reveal">
                                    <SwipeItem Text="Delete"
                                               BackgroundColor="#C62828"
                                               Invoked="OnDeleteFieldSwipeInvoked"
                                               CommandParameter="{Binding .}" />
                                </SwipeItems>
                            </SwipeView.RightItems>
                            <Border Margin="0,6"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 14"
                                    BackgroundColor="White"
                                    Padding="14">
                                <VerticalStackLayout Spacing="8">
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                        <VerticalStackLayout>
                                            <Label Text="{Binding Name}"
                                                   FontAttributes="Bold"
                                                   FontSize="18"
                                                   TextColor="#1E2A33" />
                                            <Label Text="{Binding Location}"
                                                   FontSize="13"
                                                   TextColor="#60707B" />
                                        </VerticalStackLayout>
                                        <Label Grid.Column="1"
                                               Text="{Binding AcresText}"
                                               TextColor="#2E7D32"
                                               FontAttributes="Bold"
                                               VerticalOptions="Center" />
                                    </Grid>

                                    <HorizontalStackLayout Spacing="10">
                                        <Label Text="{Binding RegionName}"
                                               FontSize="12"
                                               TextColor="#4C5C68" />
                                        <Label Text="•"
                                               FontSize="12"
                                               TextColor="#4C5C68" />
                                        <Label Text="{Binding PlantingsText}"
                                               FontSize="12"
                                               TextColor="#4C5C68" />
                                    </HorizontalStackLayout>

                                    <Label Text="{Binding CropsPreview}"
                                           FontSize="12"
                                           TextColor="#1E2A33"
                                           LineBreakMode="TailTruncation" />
                                </VerticalStackLayout>
                            </Border>
                        </SwipeView>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>
    </Grid>
</ContentPage>
